set shell := ["bash", "-cu"]
set dotenv-load := true

uatu     := env_var_or_default("UATU", "uatu")
avd      := env_var_or_default("AVD", "")
duration := env_var_or_default("DURATION", "1m")
seed     := env_var_or_default("SEED", "0")
output   := env_var_or_default("OUTPUT", justfile_directory() / "runs")
android  := justfile_directory() / "android"

default:
    @just --list

# Build and install the sample APK on a running emulator/device.
install:
    cd {{android}} && ./gradlew installDebug

# Remove the sample APK from the connected device.
uninstall:
    cd {{android}} && ./gradlew uninstallDebug

# Remove the gradle build directory.
clean:
    cd {{android}} && ./gradlew clean

# Run 'uatu test' against the sample app. Uses a connected device if one is
# online, otherwise boots AVD=<name> if provided.
test:
    #!/usr/bin/env bash
    set -euo pipefail
    avd_flag=()
    if [[ -n "{{avd}}" ]]; then
      avd_flag=(--avd "{{avd}}")
    fi
    "{{uatu}}" test \
      --spec "{{justfile_directory()}}/spec.ts" \
      --bundle-id dev.uatu.sample \
      "${avd_flag[@]}" \
      --duration "{{duration}}" \
      --seed "{{seed}}" \
      --output "{{output}}"
