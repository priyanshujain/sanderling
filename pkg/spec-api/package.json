{
  "name": "@sanderling/spec",
  "version": "0.0.0-dev",
  "description": "TypeScript spec API for sanderling, a property-based UI fuzzer for mobile apps.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./defaults/properties": {
      "types": "./dist/defaults/properties.d.ts",
      "import": "./dist/defaults/properties.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/priyanshujain/sanderling.git",
    "directory": "pkg/spec-api"
  },
  "homepage": "https://github.com/priyanshujain/sanderling",
  "bugs": {
    "url": "https://github.com/priyanshujain/sanderling/issues"
  },
  "license": "Apache-2.0",
  "author": "Priyanshu Jain",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
