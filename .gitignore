# Sidecar fat JAR. Build artifact copied in by `make sanderling` before
# `go build -tags withsidecar`. Never commit: it's ~130 MB.
internal/sidecar/assets/sidecar-all.jar

# spec-api compiled output
pkg/spec/dist/

# goreleaser local output
/dist/

# inspect web bundle output (real bundle wired in Stage 4 via Makefile/CI).
# Track only the stub index.html + .gitkeep so //go:embed succeeds.
/internal/inspect/dist/*
!/internal/inspect/dist/.gitkeep
!/internal/inspect/dist/index.html

# inspect web frontend
inspect-ui/node_modules/
inspect-ui/dist/
inspect-ui/.vite/

# folio-web frontend
examples/folio-web/node_modules/
examples/folio-web/dist/
examples/folio-web/.vite/

# d2 diagrams render into build/site/_assets/diagrams; keep sources only
/docs/_diagrams/*.svg
/docs/_diagrams/*.png

# coding agent files
.claude/
.claude/*

